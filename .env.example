# Environment variables declared in this file are automatically made available to Prisma.
# See the documentation for more detail: https://pris.ly/d/prisma-schema#accessing-environment-variables-from-the-schema

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

DATABASE_URL="postgresql://postgres:password@localhost:5432/jntuh"
RABBITMQ_URL="amqp://admin:admin@localhost:5672/"
QUEUE_NAME="default_queue"
REDIS_URL="redis://localhost:6379/0"

# S3 / grace-marks proof storage. For local dev, point at the MinIO sidecar
# defined in docker-compose.yml. In production leave S3_ENDPOINT_URL blank
# and S3_PUBLIC_URL_BASE blank so the AWS defaults apply.
AWS_ACCESS_KEY_ID="minioadmin"
AWS_SECRET_ACCESS_KEY="minioadmin"
AWS_REGION="us-east-1"
S3_BUCKET_NAME="jntuh-grace-proofs"
S3_ENDPOINT_URL="http://localhost:9000"
S3_PUBLIC_URL_BASE="http://localhost:9000/jntuh-grace-proofs"

# Shared secret that gates the admin `grace-marks/proofs/pending` endpoint.
# Use a strong random string in production.
GRACE_MARKS_ADMIN_KEY="changeme-dev"

# Shared secret for the X-Api-Key header guard. When set, every non-MCP API
# request must send an X-Api-Key header matching this exactly (keep it equal
# to the web frontend's NEXT_PUBLIC_API_KEY); when unset, any non-empty
# X-Api-Key passes. The Android app bypasses via User-Agent either way.
API_ACCESS_KEY="changeme-dev"

# Set to "production" to disable the interactive docs (/docs, /redoc,
# /openapi.json). Defaults to "development".
ENVIRONMENT="development"

# Optional agentic chatbot. The API still starts when these are absent; only
# POST /api/chatbot returns 503 until all three provider values are configured.
# CHATBOT_BASE_URL should include the OpenAI-compatible API prefix (usually /v1).
CHATBOT_API_KEY=""
CHATBOT_BASE_URL="https://api.openai.com/v1"
CHATBOT_MODEL=""
CHATBOT_TIMEOUT_SECONDS="30"
CHATBOT_MAX_ITERATIONS="4"
CHATBOT_MAX_TOOL_CALLS="6"
CHATBOT_MAX_OUTPUT_TOKENS="800"
